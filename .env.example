# ─────────────────────────────────────────────────────────────────────────────
# Crest — deployment environment. Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (must match the Postgres service in docker-compose) ──────────────
POSTGRES_USER=crest
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=crest
DATABASE_URL=postgresql://crest:change-me-strong@db:5432/crest

# ── Session signing (any long random string) ─────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── Credential encryption (REQUIRED — used to encrypt stored provider keys) ───
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Google OAuth (only if you set auth.enabled=true in config.json) ───────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram bot (optional — leave blank to disable) ──────────────────────────
TELEGRAM_BOT_TOKEN=

# ── LLM providers (optional — add the ones you use; all have free tiers) ──────
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GITHUB_MODELS_TOKEN=
NVIDIA_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
