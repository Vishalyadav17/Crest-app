# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/crest

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── Email digest (Gmail app-password) ─────────────────────────────────────────
# Create an app password at: https://myaccount.google.com/apppasswords
# Leave blank to disable email sending (app still runs; test-digest still works)
SMTP_USER=you@gmail.com
SMTP_PASS=

# ── Telegram bot ──────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather in Telegram → get token
# 2. Start the app — bot auto-polls for /start <code> messages
# 3. In Settings → Connections → generate link code → click deep link → done
# Leave blank to disable Telegram (long-poll job no-ops silently)
TELEGRAM_BOT_TOKEN=

# ── LLM providers ─────────────────────────────────────────────────────────────
# Groq (free, fast) — get key at https://console.groq.com/keys
GROQ_API_KEY=
# OpenRouter (free :free models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Cerebras (free, fast) — https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Google Gemini / Gemma (free, generous) — https://aistudio.google.com/apikey (key starts with AIza)
GEMINI_API_KEY=
# Mistral (free tier, Apache-2.0 models) — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
# GitHub Models (free) — fine-grained PAT at https://github.com/settings/tokens
GITHUB_MODELS_TOKEN=
# xAI Grok (paid, $5 prepaid) — https://console.x.ai
XAI_API_KEY=

# ── Encryption (for future credential storage) ────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPT_KEY=
